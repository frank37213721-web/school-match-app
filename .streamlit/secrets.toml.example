# Streamlit Secrets Configuration
# Copy this to .streamlit/secrets.toml for local development
# For production, set these in your Streamlit Cloud dashboard

[ADMIN_USER]
value = "admin"

[ADMIN_PASSWORD_HASH]
# This is the bcrypt hash for "admin123"
# You can generate a new hash using: 
# python generate_admin_hash.py your_password
value = "$2b$12$naO2G6NObFTrWrV6UyKs3uiu3oMx32U.FoYiC9Hhgc.K5CNGdsX9m"
